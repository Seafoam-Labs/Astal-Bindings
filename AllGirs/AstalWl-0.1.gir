				</instance-parameter>
			</parameters>
		</method>
		<method name="get_outputs" c:identifier="astal_wl_registry_get_outputs">
			<doc xml:whitespace="preserve">Returns a list of all known outputs.</doc>
			<return-value transfer-ownership="container">
				<type name="GLib.List" c:type="GList*">

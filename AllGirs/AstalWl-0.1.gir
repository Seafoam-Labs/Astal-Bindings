					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
				<parameter name="id" transfer-ownership="none">
					<type name="guint32" c:type="guint32" />
				</parameter>
			</parameters>
		</method>
		<method name="get_output_by_name" c:identifier="astal_wl_registry_get_output_by_name">
			<doc xml:whitespace="preserve">Looks up an output by its compositor-assigned name.</doc>
			<return-value transfer-ownership="full" nullable="1">
				<type name="AstalWl.Output" c:type="AstalWlOutput*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
				<parameter name="name" transfer-ownership="none">
					<type name="utf8" c:type="const gchar*" />
				</parameter>
			</parameters>
		</method>
		<method name="get_output_by_wl_output" c:identifier="astal_wl_registry_get_output_by_wl_output" introspectable="0">
			<doc xml:whitespace="preserve">Looks up an `Output` by its underlying `wl_output`.</doc>
			<return-value transfer-ownership="full" nullable="1">
				<type name="AstalWl.Output" c:type="AstalWlOutput*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
				<parameter name="wl_output" transfer-ownership="none">
					<type name="Wl.Output" c:type="struct wl_output*" />
				</parameter>
			</parameters>
		</method>
		<method name="get_seat_by_id" c:identifier="astal_wl_registry_get_seat_by_id">
			<doc xml:whitespace="preserve">Looks up a seat by its global id.</doc>
			<return-value transfer-ownership="full" nullable="1">

			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
			</parameters>
		</method>
		<method name="get_seats" c:identifier="astal_wl_registry_get_seats">
			<doc xml:whitespace="preserve">Returns a list of all known seats.</doc>
			<return-value transfer-ownership="container">
				<type name="GLib.List" c:type="GList*">

				<parameter name="wl_seat" transfer-ownership="none">
					<type name="Wl.Seat" c:type="struct wl_seat*" />
				</parameter>
			</parameters>
		</method>
		<constructor name="new" c:identifier="astal_wl_registry_new">
			<return-value transfer-ownership="full">
				<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
			</return-value>
		</constructor>
		<glib:signal name="global-added">
			<doc xml:whitespace="preserve">Emitted whenever a new global is announced by the compositor.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="global" transfer-ownership="none">
					<type name="AstalWl.Global" c:type="AstalWlGlobal*" />
				</parameter>
			</parameters>
		</glib:signal>
		<glib:signal name="global-removed">
			<doc xml:whitespace="preserve">Emitted whenever a new global is removed by the compositor.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="global" transfer-ownership="none">
					<type name="AstalWl.Global" c:type="AstalWlGlobal*" />
				</parameter>
			</parameters>
		</glib:signal>
		<glib:signal name="output-added">
			<doc xml:whitespace="preserve">Emitted after a new [class@AstalWl.Output] has been created and bound.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="output" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</parameter>
			</parameters>
		</glib:signal>
		<glib:signal name="output-removed">
			<doc xml:whitespace="preserve">Emitted just before an [class@AstalWl.Output] is removed from the List.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="output" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</parameter>
			</parameters>
		</glib:signal>
		<glib:signal name="seat-added">
			<doc xml:whitespace="preserve">Emitted after a new [class@AstalWl.Seat] has been created and bound.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="seat" transfer-ownership="none">
					<type name="AstalWl.Seat" c:type="AstalWlSeat*" />
				</parameter>
			</parameters>
		</glib:signal>
		<glib:signal name="seat-removed">
			<doc xml:whitespace="preserve">Emitted just before a [class@AstalWl.Seat] is removed.</doc>
			<return-value transfer-ownership="full">
				<type name="none" c:type="void" />
			</return-value>
			<parameters>
				<parameter name="seat" transfer-ownership="none">
					<type name="AstalWl.Seat" c:type="AstalWlSeat*" />
				</parameter>
			</parameters>
		</glib:signal>
	</class>
	<record name="RegistryClass" c:type="AstalWlRegistryClass" glib:is-gtype-struct-for="Registry">
		<field name="parent_class" readable="0" private="1">
			<type name="GObject.ObjectClass" c:type="GObjectClass" />
		</field>
	</record>
	<record name="RegistryPrivate" c:type="AstalWlRegistryPrivate" disguised="1" />
	<class name="Output" c:type="AstalWlOutput" c:symbol-prefix="output" glib:type-name="AstalWlOutput" glib:get-type="astal_wl_output_get_type" glib:type-struct="OutputClass" parent="GObject.Object">
		<doc xml:whitespace="preserve">Represents a display output device and tracks properties associated with it.
This class listens to Wayland `wl_output` and optional `zxdg_output_v1` events if supported by the compositor to maintain accurate state 
information.</doc>
		<field name="parent_instance" readable="0" private="1">
			<type name="GObject.Object" c:type="GObject" />
		</field>
		<field name="priv" readable="0" private="1">
			<type name="OutputPrivate" c:type="AstalWlOutputPrivate*" />
		</field>
		<method name="get_wl_output" c:identifier="astal_wl_output_get_wl_output" introspectable="0">
			<doc xml:whitespace="preserve">Returns the underlying `wl_output` proxy pointer.</doc>
			<return-value transfer-ownership="none">
				<type name="Wl.Output" c:type="struct wl_output*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="id" writable="1" construct-only="1">
			<doc xml:whitespace="preserve">The unique registry ID of this output as provided by the compositor.</doc>
			<type name="guint32" c:type="guint32" />
		</property>
		<method name="get_id" c:identifier="astal_wl_output_get_id">
			<return-value transfer-ownership="none">
				<type name="guint32" c:type="guint32" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="geometry" writable="1">
			<doc xml:whitespace="preserve">The logical geometry of the output in compositor coordinates. This reflects the visible area after applying scaling and transform.</doc>
			<type name="AstalWl.Rectangle" c:type="AstalWlRectangle*" />
		</property>
		<method name="get_geometry" c:identifier="astal_wl_output_get_geometry">
			<return-value transfer-ownership="none" nullable="1">
				<type name="AstalWl.Rectangle" c:type="AstalWlRectangle*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="physical-width" writable="1">
			<doc xml:whitespace="preserve">The physical width of the output in millimeters.</doc>
			<type name="gint" c:type="gint" />
		</property>
		<method name="get_physical_width" c:identifier="astal_wl_output_get_physical_width">
			<return-value transfer-ownership="none">
				<type name="gint" c:type="gint" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="physical-height" writable="1">
			<doc xml:whitespace="preserve">The physical height of the output in millimeters.</doc>
			<type name="gint" c:type="gint" />
		</property>
		<method name="get_physical_height" c:identifier="astal_wl_output_get_physical_height">
			<return-value transfer-ownership="none">
				<type name="gint" c:type="gint" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="refresh-rate" writable="1">
			<doc xml:whitespace="preserve">The refresh rate of the current output mode in Hz.</doc>
			<type name="gdouble" c:type="gdouble" />
		</property>
		<method name="get_refresh_rate" c:identifier="astal_wl_output_get_refresh_rate">
			<return-value transfer-ownership="none">
				<type name="gdouble" c:type="gdouble" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="transform" writable="1">
			<doc xml:whitespace="preserve">The rotation or flip transform of the output surface.</doc>
			<type name="AstalWl.OutputTransform" c:type="AstalWlOutputTransform" />
		</property>
		<method name="get_transform" c:identifier="astal_wl_output_get_transform">
			<return-value transfer-ownership="none">
				<type name="AstalWl.OutputTransform" c:type="AstalWlOutputTransform" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="subpixel" writable="1">
			<doc xml:whitespace="preserve">The subpixel layout of the physical monitor.</doc>
			<type name="AstalWl.OutputSubpixel" c:type="AstalWlOutputSubpixel" />
		</property>
		<method name="get_subpixel" c:identifier="astal_wl_output_get_subpixel">
			<return-value transfer-ownership="none">
				<type name="AstalWl.OutputSubpixel" c:type="AstalWlOutputSubpixel" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="make" writable="1">
			<doc xml:whitespace="preserve">The manufacturer name of the display device.</doc>
			<type name="utf8" c:type="gchar*" />
		</property>
		<method name="get_make" c:identifier="astal_wl_output_get_make">
			<return-value transfer-ownership="none" nullable="1">
				<type name="utf8" c:type="const gchar*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="model" writable="1">
			<doc xml:whitespace="preserve">The product or model name of the display device.</doc>
			<type name="utf8" c:type="gchar*" />
		</property>
		<method name="get_model" c:identifier="astal_wl_output_get_model">
			<return-value transfer-ownership="none" nullable="1">
				<type name="utf8" c:type="const gchar*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="scale" writable="1">
			<doc xml:whitespace="preserve">The scaling factor of the output.</doc>
			<type name="gdouble" c:type="gdouble" />
		</property>
		<method name="get_scale" c:identifier="astal_wl_output_get_scale">
			<return-value transfer-ownership="none">
				<type name="gdouble" c:type="gdouble" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="name" writable="1">
			<doc xml:whitespace="preserve">The compositor-assigned name of this output. Usually corresponds to an identifier like "HDMI-A-1".</doc>
			<type name="utf8" c:type="gchar*" />
		</property>
		<method name="get_name" c:identifier="astal_wl_output_get_name">
			<return-value transfer-ownership="none" nullable="1">
				<type name="utf8" c:type="const gchar*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Output" c:type="AstalWlOutput*" />
				</instance-parameter>
			</parameters>
		</method>
		<property name="description" writable="1">
			<doc xml:whitespace="preserve">A description of the output.</doc>
			<type name="utf8" c:type="gchar*" />
		</property>
		<method name="get_description" c:identifier="astal_wl_output_get_description">
			<return-value transfer-ownership="none" nullable="1">
				<type name="utf8" c:type="const gchar*" />
			</return-value>

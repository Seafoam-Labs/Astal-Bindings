					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
			</parameters>
		</method>
		<method name="find_globals" c:identifier="astal_wl_registry_find_globals">
			<doc xml:whitespace="preserve">Returns a list of globals, optionally filtered by interface name. If `null` is passed, all globals are returned.</doc>
			<return-value transfer-ownership="full" nullable="1">
				<type name="GLib.List" c:type="GList*">
					<type name="AstalWl.Global" c:type="AstalWlGlobal*" />
				</type>
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
				<parameter name="interface" transfer-ownership="none" nullable="1">
					<type name="utf8" c:type="const gchar*" />
				</parameter>
			</parameters>
		</method>
		<method name="get_global_by_id" c:identifier="astal_wl_registry_get_global_by_id">
			<doc xml:whitespace="preserve">Looks up a global by its numeric Iid.</doc>
			<return-value transfer-ownership="full" nullable="1">
				<type name="AstalWl.Global" c:type="AstalWlGlobal*" />
			</return-value>
			<parameters>

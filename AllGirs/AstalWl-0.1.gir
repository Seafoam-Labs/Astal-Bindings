			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
			</parameters>
		</method>
		<method name="get_registry" c:identifier="astal_wl_registry_get_registry" introspectable="0">
			<doc xml:whitespace="preserve">Returns the underlying `wl_registry` object.</doc>
			<return-value transfer-ownership="none" nullable="1">
				<type name="Wl.Registry" c:type="struct wl_registry*" />
			</return-value>
			<parameters>
				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
			</parameters>
		</method>
		<method name="get_display" c:identifier="astal_wl_registry_get_display" introspectable="0">
			<doc xml:whitespace="preserve">Returns the underlying `wl_display` used by this registry.</doc>

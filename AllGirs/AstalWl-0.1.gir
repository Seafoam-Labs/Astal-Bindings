				<instance-parameter name="self" transfer-ownership="none">
					<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
				</instance-parameter>
				<parameter name="id" transfer-ownership="none">
					<type name="guint32" c:type="guint32" />
				</parameter>
			</parameters>
		</method>
		<method name="get_seat_by_name" c:identifier="astal_wl_registry_get_seat_by_name">
			<doc xml:whitespace="preserve">Looks up a seat by its compositor-assigned name.</doc>

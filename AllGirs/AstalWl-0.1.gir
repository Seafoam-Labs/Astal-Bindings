<?xml version='1.0' encoding='utf-8'?>
<repository xmlns="http://www.gtk.org/introspection/core/1.0" xmlns:c="http://www.gtk.org/introspection/c/1.0" xmlns:glib="http://www.gtk.org/introspection/glib/1.0" version="1.2">
<include name="GObject" version="2.0" />
<include name="GLib" version="2.0" />
<package name="astal-wl" />
<c:include name="astal-wl.h" />
<namespace name="AstalWl" version="0.1" c:prefix="AstalWl" c:identifier-prefixes="AstalWl" c:symbol-prefixes="astal_wl">
	<class name="Registry" c:type="AstalWlRegistry" c:symbol-prefix="registry" glib:type-name="AstalWlRegistry" glib:get-type="astal_wl_registry_get_type" glib:type-struct="RegistryClass" parent="GObject.Object">
		<doc xml:whitespace="preserve">Wraps the Wayland `wl_registry` interface and keeps track of all announced globals, outputs and seats.
It exposes high-level collections and lookup helpers and emits signals when globals, outputs or seats are added or removed.</doc>
		<field name="parent_instance" readable="0" private="1">
			<type name="GObject.Object" c:type="GObject" />
		</field>
		<field name="priv" readable="0" private="1">
			<type name="RegistryPrivate" c:type="AstalWlRegistryPrivate*" />
		</field>
		<field name="globals" writable="1">
			<doc xml:whitespace="preserve">Hash table of all known Wayland globals keyed by their numeric ID.</doc>
			<type name="GLib.HashTable" c:type="GHashTable*">
				<type name="guint32" c:type="guint32" />
				<type name="AstalWl.Global" c:type="AstalWlGlobal*" />
			</type>
		</field>
		<field name="outputs" writable="1">
			<doc xml:whitespace="preserve">Hash table of all currently bound outputs keyed by their global ID.</doc>
			<type name="GLib.HashTable" c:type="GHashTable*">
				<type name="guint32" c:type="guint32" />
				<type name="AstalWl.Output" c:type="AstalWlOutput*" />
			</type>
		</field>
		<field name="seats" writable="1">
			<doc xml:whitespace="preserve">Hash table of all currently bound seats keyed by their global ID.</doc>
			<type name="GLib.HashTable" c:type="GHashTable*">
				<type name="guint32" c:type="guint32" />
				<type name="AstalWl.Seat" c:type="AstalWlSeat*" />
			</type>
		</field>
		<function name="get_default" c:identifier="astal_wl_registry_get_default">
			<doc xml:whitespace="preserve">Returns the singleton `Registry` instance.
The first call connects to the Wayland display and sets up the underlying `wl_registry` listener.</doc>
			<return-value transfer-ownership="none">
				<type name="AstalWl.Registry" c:type="AstalWlRegistry*" />
			</return-value>
		</function>
		<method name="get_globals" c:identifier="astal_wl_registry_get_globals">
			<doc xml:whitespace="preserve">Returns a list of all known globals.</doc>
			<return-value transfer-ownership="container">

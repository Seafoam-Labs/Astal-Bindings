				</parameter>
			</parameters>
		</method>
		<method name="get_seat_by_wl_seat" c:identifier="astal_wl_registry_get_seat_by_wl_seat" introspectable="0">
			<doc xml:whitespace="preserve">Looks up a `Seat` by its underlying `wl_seat`.</doc>
			<return-value transfer-ownership="full" nullable="1">
				<type name="AstalWl.Seat" c:type="AstalWlSeat*" />
